---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="About">
  <section class="hero min-h-[70vh] rounded-box bg-base-100 shadow">
    <div class="hero-content text-center">
      <div class="max-w-md">
        <h1 class="text-5xl font-bold">Acerca de Nosotros</h1>
        <p class="py-6">
          Este es un proyecto base construido con Astro, Tailwind CSS y daisyUI.
          Aquí puedes agregar información sobre tu sitio o proyecto.
        </p>
        <button class="btn btn-primary">Saber Más</button>
      </div>
    </div>
  </section>
</BaseLayout>