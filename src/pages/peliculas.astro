---
import BaseLayout from "../layouts/BaseLayout.astro";
import Search from "../components/Search.vue";

const API_KEY = import.meta.env.PUBLIC_TMDB_API_KEY;
// console.log("KEY:", import.meta.env.PUBLIC_TMDB_API_KEY);

let movies = [];
let error = "";

try {
  const res = await fetch(
    `https://api.themoviedb.org/3/movie/popular?api_key=${API_KEY}&language=es-ES&page=1`,
  );

  const data = await res.json();

  if (!res.ok) {
    error = data.status_message || "Error al consultar TMDB";
  } else {
    movies = data.results.slice(0, 20) ?? [];
  }
} catch (err) {
  error = "No se pudieron cargar las películas";
  console.error(err);
}
---

<BaseLayout title="Películas populares">
  <main>
    <h1 class="text-5xl font-bold mb-8 text-center">Películas populares</h1>

    {error ? (
      <p class="text-center text-red-500">{error}</p>
    ) : (
      <Search client:load movies={movies} apiKey={API_KEY} />
    )}
  </main>
</BaseLayout>

